---
layout: base.njk
---
<main>

  <div class="container">
    <div class="article-header">
      <a href="/" class="back-link">&larr; All posts</a>
      <p class="article-meta">{{ date | readableDate }} &middot; {{ readTime }} min read</p>
      <h1>{{ title }}</h1>
      <div class="article-author">
        <img src="{{ site.author.avatar }}" alt="">
        <span><strong>by {{ site.author.name }}</strong>{{ site.author.role }}</span>
      </div>
    </div>
  </div>

  <div class="article-feature-image">
    <img src="{{ image }}" alt="{{ imageAlt }}">
  </div>

  <article class="article-body">
    {{ content | safe }}
  </article>

  <div class="article-footer">
    <a href="/" class="back-link">&larr; Back to all posts</a>
  </div>

</main>
